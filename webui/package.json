    "@testing-library/user-event": "^14.6.1",
    "@tsconfig/svelte": "^5.0.6",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.18",
    "daisyui": "^5.5.19",
    "jsdom": "^28.1.0",
    "svelte": "^5.45.2",
    "svelte-check": "^4.3.4",
    "svelte-spa-router": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
